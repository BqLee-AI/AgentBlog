# ===== 运行环境 =====
NODE_ENV=development
PORT=3000

# ===== 数据库（SQLite 文件路径）=====
DATABASE_URL=./data/app.db

# ===== JWT（会话鉴权，详见 docs/design/04）=====
# 务必替换为至少 32 字符的随机串
JWT_SECRET=change-me-please-use-a-long-random-string-of-32-chars
# 支持 7d / 2h / 3600（秒）；Hono JWT 不接受字符串，env.ts 内会转秒
JWT_EXPIRES_IN=7d

# ===== 默认超管（首次 seed 用，见 docs/design/03）=====
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_PASSWORD=admin12345

# ===== Credits 计费（见 docs/design/08）=====
CREDITS_PER_MCP_CALL=1
TOKENS_PER_CREDIT=1000

# ===== 在线 Agent（Vercel AI SDK，见 docs/design/10）=====
# AI_PROVIDER 选 openai 或 anthropic，对应下面两组 key/baseURL/model
AI_PROVIDER=openai
# OpenAI（或任意 OpenAI 兼容端点：DeepSeek/智谱/Moonshot/Ollama 等）
OPENAI_API_KEY=sk-xxx
# 可选：自定义 baseURL（代理或第三方兼容端点）；留空走 https://api.openai.com/v1
# OPENAI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
# Anthropic（AI_PROVIDER=anthropic 时使用）
# ANTHROPIC_API_KEY=sk-ant-xxx
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ===== 图片上传（见 docs/design/11）=====
UPLOAD_DIR=./data/uploads
UPLOAD_MAX_SIZE_MB=5
