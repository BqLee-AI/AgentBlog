# ===== 运行环境 =====
NODE_ENV=development
PORT=3000

# ===== 数据库（SQLite 文件路径）=====
DATABASE_URL=./data/app.db

# ===== JWT（会话鉴权，详见 docs/design/04）=====
# 务必替换为至少 32 字符的随机串
JWT_SECRET=change-me-please-use-a-long-random-string-of-32-chars
# 支持 7d / 2h / 3600（秒）；Hono JWT 不接受字符串，env.ts 内会转秒
JWT_EXPIRES_IN=7d

# ===== 默认超管（首次 seed 用，见 docs/design/03）=====
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_PASSWORD=admin12345

# ===== Credits 计费（见 docs/design/08）=====
CREDITS_PER_MCP_CALL=1
TOKENS_PER_CREDIT=1000

# ===== 在线 Agent（Vercel AI SDK，见 docs/design/10）=====
AI_PROVIDER=openai
OPENAI_API_KEY=sk-xxx
AI_MODEL=gpt-4o-mini

# ===== 图片上传（见 docs/design/11）=====
UPLOAD_DIR=./data/uploads
UPLOAD_MAX_SIZE_MB=5
