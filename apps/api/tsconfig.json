{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "types": ["bun"],
    "module": "Preserve",
    "moduleDetection": "force",
    "allowImportingTsExtensions": true,

    "paths": {
      "@/*": ["./src/*"],
      "@agentblog/shared": ["../../packages/shared/src/index.ts"],
      "@agentblog/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": ["src/**/*.ts", "*.config.ts"],
  "exclude": ["node_modules", "dist"]
}
